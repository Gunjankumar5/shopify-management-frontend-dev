{
  "ignoreFiles": ["**/node_modules/**", "dist/**"],
  "overrides": [
    {
      "files": ["src/**/*.css"],
      "customSyntax": "postcss-scss"
    }
  ],
  "extends": [
    "stylelint-config-standard"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "variants",
          "responsive",
          "screen"
        ]
      }
    ],
    "no-descending-specificity": null
  }
}
